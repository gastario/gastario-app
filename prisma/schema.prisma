model FoodLabel {
  id       String @id @default(cuid())
  tenantId String

  productName    String
  customerName   String?
  productionDate DateTime
  bestBeforeDate DateTime
  batchNumber    String?
  storageNote    String?
  allergens      String?
  quantityText   String?

  labelCount Int    @default(1)
  labelSize  String @default("76x51")
  status     String @default("CREATED")

  printedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productionDate])
  @@index([bestBeforeDate])
  @@index([createdAt])
}

model RegistrationInvite {
  id        String    @id @default(cuid())
  code      String    @unique
  note      String?
  email     String?
  usedAt    DateTime?
  usedBy    String?
  createdAt DateTime  @default(now())
  expiresAt DateTime?
}

model InventoryItem {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  category     String?
  unit         String   @default("Stueck")
  currentStock Float    @default(0)
  minStock     Float    @default(0)
  supplierName String?
  location     String?
  notes        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
  productId String?

  @@index([tenantId])
  @@index([active])
}

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  category    String?
  contactName String?
  email       String?
  phone       String?
  items       String?
  orderDays   String?
  notes       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product   Product? @relation(fields: [productId], references: [id])
  productId String?

  @@index([tenantId])
  @@index([active])
}

model ProductRecipeItem {
  id              String   @id @default(cuid())
  tenantId        String
  productId       String
  ingredientName  String
  quantityPerUnit Float
  unit            String   @default("g")
  supplierName    String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model DeliveryTour {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  driverName   String?
  driverEmail  String?
  driverPhone  String?
  deliveryDate DateTime?
  status       String    @default("OPEN")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stops  DeliveryStop[]

  @@index([tenantId])
  @@index([deliveryDate])
  @@index([status])
}

model DeliveryStop {
  id          String   @id @default(cuid())
  tenantId    String
  tourId      String
  orderId     String
  sortOrder   Int      @default(0)
  plannedTime String?
  status      String   @default("OPEN")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tour   DeliveryTour @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, orderId])
  @@index([tenantId])
  @@index([tourId])
  @@index([orderId])
}


enum BillingMode {
  UNDECIDED
  DIRECT_INVOICE
  EXTERNAL_INVOICE
  PLATFORM_CREDIT
  NO_INVOICE
}

enum BillingStatus {
  NOT_BILLED
  READY_TO_INVOICE
  INVOICED
  INVOICED_EXTERNALLY
  WAITING_FOR_CREDIT
  CREDIT_RECEIVED
  NOT_RELEVANT
}

enum InvoiceType {
  DIRECT
  EXTERNAL
  PLATFORM_CREDIT
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
  CORRECTED
}

enum InvoiceNumberSource {
  GASTARIO
  CASH_REGISTER
  LEXWARE
  PLATFORM
  MANUAL
}



model Invoice {
  id        String @id @default(cuid())
  tenantId  String
  orderId   String?

  type         InvoiceType         @default(DIRECT)
  status       InvoiceStatus       @default(DRAFT)
  numberSource InvoiceNumberSource @default(MANUAL)

    language     InvoiceLanguage @default(DE)
internalNumber        String?
  externalInvoiceNumber String?
  sourceSystem          String?

  invoiceDate DateTime?
  serviceDate DateTime?
  dueDate     DateTime?

  customerName    String
  customerEmail   String?
  customerAddress String?

    customerCountry String @default("DE")
sellerName      String?
  sellerAddress   String?
  sellerTaxNumber String?
  sellerVatId     String?

  currency        String @default("EUR")
  netTotalCents   Int    @default(0)
  taxTotalCents   Int    @default(0)
  grossTotalCents Int    @default(0)

    reverseChargeNoteDe String?
notes       String?
  issuedAt    DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  items InvoiceItem[]

  @@unique([tenantId, externalInvoiceNumber])
  @@index([tenantId])
  @@index([orderId])
  @@index([status])
  @@index([invoiceDate])
  customerType CustomerType    @default(BUSINESS)
  taxTreatment TaxTreatment    @default(DOMESTIC_19)

  customerVatId   String?
  reverseChargeNoteEn String?
