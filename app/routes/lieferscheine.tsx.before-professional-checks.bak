                <div style={{
                  marginTop: 28,
                  display: "grid",
                  gridTemplateColumns: "1fr 1fr",
                  gap: 22
                }}>
                  <div style={{
                    borderTop: "1px solid #94a3b8",
                    paddingTop: 8,
                    color: "#64748b",
                    fontWeight: 800
                  }}>
                    Uebergabe / Fahrer
                  </div>

                  <div style={{
                    borderTop: "1px solid #94a3b8",
